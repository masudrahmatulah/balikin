# ============================================
# Production Environment Variables
# Copy this to .env.production and fill in the values
# ============================================

# Supabase Database
# Get from: Supabase Dashboard > Project Settings > Database > Connection String
# Use Direct connection URL for migrations, Pooler for app queries
DATABASE_URL="postgresql://postgres.[ref]:[password]@[project].supabase.co:5432/postgres"

# Better Auth
# Generate a strong random string for production
BETTER_AUTH_SECRET="generate-strong-random-string-min-32-chars"
BETTER_AUTH_URL="https://your-domain.com"
NEXT_PUBLIC_BETTER_AUTH_URL="https://your-domain.com"

# App Configuration
NEXT_PUBLIC_APP_URL="https://your-domain.com"
NODE_ENV="production"

# Email (Resend) - Optional, for production email OTP
# Get from: https://resend.com/api-keys
RESEND_API_KEY="re_[your-api-key]"

# ============================================
# Development Notes:
# ============================================
# 1. Before first deploy, run migrations manually via Supabase SQL Editor
# 2. Copy the SQL from drizzle/supabase_migration.sql
# 3. Set BETTER_AUTH_SECRET to a strong random string
# 4. Update BETTER_AUTH_URL to your production domain
# 5. For WhatsApp notifications (future): WHATSAPP_API_TOKEN
