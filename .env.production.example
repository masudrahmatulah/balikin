# ============================================
# Production Environment Variables
# Copy this to .env.production and fill in the values
# ============================================

# Supabase Database
# Get from: Supabase Dashboard > Project Settings > Database > Connection String
# Use Direct connection URL for migrations, Pooler for app queries
DATABASE_URL="postgresql://postgres.[ref]:[password]@[project].supabase.co:5432/postgres"

# Better Auth
# Generate a strong random string for production
BETTER_AUTH_SECRET="generate-strong-random-string-min-32-chars"
BETTER_AUTH_URL="https://your-domain.com"
NEXT_PUBLIC_BETTER_AUTH_URL="https://your-domain.com"

# App Configuration
NEXT_PUBLIC_APP_URL="https://your-domain.com"
NODE_ENV="production"

# Email (Resend) - Optional, for production email OTP
# Get from: https://resend.com/api-keys
RESEND_API_KEY="re_[your-api-key]"
EMAIL_FROM="Balikin <noreply@your-domain.com>"

# WhatsApp OTP (Fonnte API)
# Get your API token from https://fonnte.com
FONNTE_API_TOKEN="your-fonnte-api-token"
FONNTE_DEVICE_ID=""
FONNTE_BASE_URL="https://api.fonnte.com"
WHATSAPP_PROVIDER_STANDARD="fonnte_standard"
WHATSAPP_PROVIDER_PRIORITY="fonnte_priority"
FONNTE_PRIORITY_API_TOKEN=""
FONNTE_PRIORITY_DEVICE_ID=""
FONNTE_PRIORITY_BASE_URL="https://api.fonnte.com"

# WhatsApp Order Number
# Nomor WhatsApp untuk menerima pesanan (tanpa + atau 0 di depan, contoh: 6281234567890)
WHATSAPP_ORDER_NUMBER="6281234567890"

# ============================================
# Development Notes:
# ============================================
# 1. Before first deploy, run migrations manually via Supabase SQL Editor
# 2. Copy the SQL from drizzle/supabase_migration.sql
# 3. Set BETTER_AUTH_SECRET to a strong random string
# 4. Update BETTER_AUTH_URL to your production domain
# 5. Acrylic Premium bisa memakai Fonnte priority token/device terpisah untuk jalur alert prioritas
