# ==============================================
# ENVIRONMENT VARIABLES TEMPLATE
# ==============================================
# Use this file as reference for setting up environment variables
# DO NOT commit actual values to git!

# ===========================================
# DATABASE CONFIGURATION (Required)
# ===========================================
# Format: postgresql://postgres:PASSWORD@HOST:PORT/DATABASE
# Get from: Supabase Dashboard → Project Settings → Database
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# ===========================================
# APP CONFIGURATION (Required)
# ===========================================
# Your production URL (Vercel will auto-set this, but you can override)
NEXT_PUBLIC_APP_URL=https://balikin.vercel.app
NODE_ENV=production

# ===========================================
# BETTER AUTH CONFIGURATION (Required)
# ===========================================
# Generate a strong secret key for production
# Use: openssl rand -base64 32
BETTER_AUTH_SECRET=change-this-to-a-strong-random-string-min-32-chars

# Your production domain for auth URLs
BETTER_AUTH_URL=https://balikin.vercel.app
NEXT_PUBLIC_BETTER_AUTH_URL=https://balikin.vercel.app

# Google OAuth (Optional - for Google SSO)
# Get from: https://console.cloud.google.com/apis/credentials
# Create OAuth 2.0 Client ID with redirect URI: https://your-domain.com/api/auth/callback/google
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# ===========================================
# EMAIL SERVICE (Optional but Recommended)
# ===========================================
# Get from: https://resend.com/api-keys
# Used for: OTP verification, email alerts
RESEND_API_KEY=re_your_resend_api_key_here

# ===========================================
# WHATSAPP SERVICE (Optional)
# ===========================================
# Get from: https://fonnte.com
# Used for: WhatsApp alerts, order notifications

# Standard WhatsApp API (for free/sticker tags)
FONNTE_API_TOKEN=your_fonnte_api_token
FONNTE_DEVICE_ID=your_device_id_08xxxxxxxx
FONNTE_BASE_URL=https://api.fonnte.com

# Priority WhatsApp API (for premium tags)
FONNTE_PRIORITY_API_TOKEN=your_priority_api_token
FONNTE_PRIORITY_DEVICE_ID=your_priority_device_id_08xxxxxxxx
FONNTE_PRIORITY_BASE_URL=https://api.fonnte.com

# WhatsApp order number (for sticker orders)
WHATSAPP_ORDER_NUMBER=6282255905612
WHATSAPP_PROVIDER_STANDARD=fonnte_standard
WHATSAPP_PROVIDER_PRIORITY=fonnte_priority

# ===========================================
# OPTIONAL VARIABLES
# ===========================================
# Add these if you need additional functionality

# Analytics (Optional)
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Error Tracking (Optional)
# SENTRY_DSN=your-sentry-dsn

# Feature Flags (Optional)
# NEXT_PUBLIC_ENABLE_ANALYTICS=true
# NEXT_PUBLIC_ENABLE_ERROR_TRACKING=false
